# ─────────────────────────────────────────────
# Document Integrity System — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Azure Service Bus (for async queue processing)
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=document-analysis

# Azure Blob Storage (for PDF uploads)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=pdf-uploads

# LanguageTool API
LANGUAGETOOL_API_URL=https://api.languagetool.org/v2/check
LANGUAGETOOL_LANGUAGE=en-US

# Analysis limits
MAX_TEXT_LENGTH=10000
MAX_FILE_SIZE_MB=50
